# =============================================================================
# Local RAG System Environment Variables
# =============================================================================
# Copy this file to .env and customize the values for your environment

# -----------------------------------------------------------------------------
# n8n Configuration
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=UTC

# n8n External Port (host machine)
N8N_EXTERNAL_PORT=5678

# Allow all built-in and external modules in code nodes
NODE_FUNCTION_ALLOW_BUILTIN=*
NODE_FUNCTION_ALLOW_EXTERNAL=*

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password
POSTGRES_DB=n8n_rag

# PostgreSQL External Port (host machine)
POSTGRES_EXTERNAL_PORT=5436

# -----------------------------------------------------------------------------
# Qdrant Configuration
# -----------------------------------------------------------------------------
# Qdrant HTTP Port
QDRANT_HTTP_PORT=6333

# Qdrant gRPC Port
QDRANT_GRPC_PORT=6334

# Qdrant Collection Name (used in workflows)
QDRANT_COLLECTION_NAME=documents

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
# Ollama API Port (HOST side - for accessing from your machine)
# Change this if you already have Ollama running on the default port 11434
OLLAMA_PORT=11434

# Ollama Base URL (for n8n and other containers via Docker network)
# IMPORTANT: Inside Docker network, Ollama container ALWAYS listens on port 11434
# The OLLAMA_PORT above only affects the host-side port mapping
# Format: http://<container-name>:<internal-port>
OLLAMA_BASE_URL_INTERNAL=http://ollama:11434

# Ollama Base URL (for Open WebUI - uses Docker network since it's in same compose)
# Since Open WebUI runs inside Docker, it should use the Docker network
OLLAMA_BASE_URL_WEBUI=http://ollama:11434

# Default Models to Pull (comma-separated)
OLLAMA_MODELS=llama3.1:8b-instruct-q4_K_M,mistral:7b-instruct-q4_K_M,nomic-embed-text:latest

# -----------------------------------------------------------------------------
# Open WebUI Configuration
# -----------------------------------------------------------------------------
# Open WebUI External Port (host machine)
OPEN_WEBUI_PORT=3000

# Disable authentication for local development
WEBUI_AUTH=false

# Disable web search RAG (we use our custom RAG)
ENABLE_RAG_WEB_SEARCH=false

# -----------------------------------------------------------------------------
# RAG System Configuration
# -----------------------------------------------------------------------------
# Path to documents directory (relative to docker-compose.yml)
DOCUMENTS_PATH=./documents

# Chunk size for text splitting (in characters)
CHUNK_SIZE=512

# Chunk overlap for text splitting (in characters)
CHUNK_OVERLAP=100

# Vector search top-k results
VECTOR_SEARCH_TOP_K=5

# Final reranked results count
RERANK_TOP_K=5

# Embedding model dimension (multilingual-e5-large-instruct uses 1024)
EMBEDDING_DIMENSION=1024

# HuggingFace Hub offline mode — set to 1 after initial tokenizer download
# to block all outbound Hub calls (fully local operation)
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# Docker network name
NETWORK_NAME=rag-network

# -----------------------------------------------------------------------------
# Volume Configuration
# -----------------------------------------------------------------------------
# Docker volume names
VOLUME_N8N=n8n_data
VOLUME_POSTGRES=postgres_data
VOLUME_QDRANT=qdrant_data
VOLUME_OLLAMA=ollama_data
VOLUME_OPEN_WEBUI=open_webui_data

RAG_BACKEND_PORT=5008
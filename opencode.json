{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama",
        "timeout": false,
        "chunkTimeout": 900000
      },
      "models": {
        "gpt-oss:20b": {
          "name": "gpt-oss-20b"
        },
        "qwen3-coder:30b": {
          "name": "Qwen3 Coder 30B",
          "_launch": true
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next"
        }
      }
    }
  },
  "model": "ollama/qwen3-coder:30b"
}

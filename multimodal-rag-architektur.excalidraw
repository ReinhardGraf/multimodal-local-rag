    },
    {
      "type": "text",
      "id": "f_biz_text",
      "x": 483.30818939208984,
      "y": 2896.5,
      "width": 231.3836212158203,
      "height": 120,
      "text": "Mehrwert für Unternehmen\n\nWissensarbeiter finden Informationen\nin Sekunden statt Stunden. Die Pipeline\nlässt sich anpassen — besonders\nin datensensiblen Sektoren:\nMedizin, Recht, Finanzen,\nBehörden.",
      "originalText": "Mehrwert für Unternehmen\n\nWissensarbeiter finden Informationen\nin Sekunden statt Stunden. Die Pipeline\nlässt sich anpassen — besonders\nin datensensiblen Sektoren:\nMedizin, Recht, Finanzen,\nBehörden.",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 106626,
      "version": 8,
      "versionNonce": 1364255080,

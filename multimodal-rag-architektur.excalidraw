    {
      "type": "text",
      "id": "trick2_text",
      "x": 756.6301168317448,
      "y": 2150.1121910727766,
      "width": 247.4276123046875,
      "height": 105,
      "text": "GPU Preloading beim Systemstart\n\n• Modell beim Backend-Start in GPU laden\n• Kein Cold-Start bei der ersten Anfrage\n• keep_alive: -1 → Modell wird nie entladen\n• Sekunden-schnelle Antworten ab dem\n  ersten Request, ohne Wartezeit",
      "originalText": "GPU Preloading beim Systemstart\n\n• Modell beim Backend-Start in GPU laden\n• Kein Cold-Start bei der ersten Anfrage\n• keep_alive: -1 → Modell wird nie entladen\n• Sekunden-schnelle Antworten ab dem\n  ersten Request, ohne Wartezeit",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
